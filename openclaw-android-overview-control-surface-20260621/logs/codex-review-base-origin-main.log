                  deviceFamily = "Android",
                  paired = true,
                  connected = true,
                  approvalState = GatewayNodeApprovalState.PendingApproval,
                  pendingRequestId = null,
                  capabilities = emptyList(),
                  commands = emptyList(),
                ),
              ),
